# =====================================================================
# StayKonkan Backend — .gitignore
# =====================================================================

# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# Compiled classes
*.class
*.jar
*.war
!maven-wrapper.jar

# Logs
*.log
logs/

# IDE — IntelliJ
.idea/
*.iws
*.iml
*.ipr
out/

# IDE — Eclipse
.classpath
.project
.settings/
bin/

# IDE — VS Code
.vscode/

# OS
.DS_Store
Thumbs.db

# Environment / secrets — NEVER commit real values
.env
.env.*
!.env.example
*.pem
*.key
application-local.properties
application-secrets.properties

# Test / coverage
/coverage
*.exec

# Docker
docker-compose.override.yml
